<+><?xml version=\"1.0\" encoding=\"utf-8\"?>\r\n<resources>\r\n    <!-- App Title -->\r\n    <string name=\"appName\">צבע אדום</string>\r\n\r\n    <!-- Loading Dialog -->\r\n    <string name=\"loading\">אנא המתן...</string>\r\n\r\n    <!-- Registration Dialog -->\r\n    <string name=\"signing_up\">נרשם לשירות עדכוני צבע אדום...</string>\r\n\r\n    <!-- Dialog Buttons -->\r\n    <string name=\"yes\">כן</string>\r\n    <string name=\"no\">לא</string>\r\n    <string name=\"okay\">אוקי</string>\r\n    <string name=\"error\">שגיאה</string>\r\n\r\n    <!-- Update Dialog -->\r\n    <string name=\"update\">עדכון גרסה</string>\r\n    <string name=\"updateDesc\">יצאה גרסה חדשה יותר של האפליקציה (%s), מומלץ לעדכן.</string>\r\n    <string name=\"updatePositive\">עדכן</string>\r\n    <string name=\"notNow\">לא עכשיו</string>\r\n\r\n    <!-- Recent Alerts -->\r\n    <string name=\"noAlerts\">אין התרעות\\nמהיום האחרון</string>\r\n    <string name=\"recentAlerts\">התרעות אחרונות</string>\r\n\r\n    <!-- Settings -->\r\n    <string name=\"settings\">הגדרות</string>\r\n    <string name=\"advanced\">אפשרויות</string>\r\n    <string name=\"alerts\">התרעות</string>\r\n    <string name=\"advancedAlerts\">התרעות מתקדמות</string>\r\n    <string name=\"advancedSettings\">הגדרות מתקדמות</string>\r\n\r\n    <!-- Advanced Settings -->\r\n    <string name=\"advancedSettingsTitle\">הגדרות מתקדמות</string>\r\n    <string name=\"advancedSettingsDesc\">ערוך הגדרות התרעה מתקדמות</string>\r\n\r\n    <!-- Enable/Disable Notifications -->\r\n    <string name=\"notifications\">התרעות בזמן אמת</string>\r\n    <string name=\"notificationsDesc\">קבל התרעות צבע אדום בזמן אמת</string>\r\n\r\n    <!-- Area Selection -->\r\n    <string name=\"alertRegions\">אזורי התרעה</string>\r\n    <string name=\"search\">הקלד מילות חיפוש...</string>\r\n    <string name=\"allString\">הכל</string>\r\n    <string name=\"noneString\">כבוי</string>\r\n\r\n    <!-- Secondary Alerts -->\r\n    <string name=\"secondaryAlerts\">הת