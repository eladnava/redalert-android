string name=\"siren4\">סירנה 4</string>\r\n    <string name=\"siren5\">סירנה 5</string>\r\n    <string name=\"tiny\">קצר 1</string>\r\n    <string name=\"calm\">רגוע 1</string>\r\n    <string name=\"tzevaAdom\">צבע אדום</string>\r\n    <string name=\"funny\">מצחיק</string>\r\n    <string name=\"calm2\">רגוע 2</string>\r\n    <string name=\"calm3\">רגוע 3</string>\r\n    <string name=\"calm4\">רגוע 4</string>\r\n    <string name=\"calm5\">רגוע 5</string>\r\n    <string name=\"tiny2\">קצר 2</string>\r\n    <string name=\"tiny3\">קצר 3</string>\r\n    <string name=\"tiny4\">קצר 4</string>\r\n    <string name=\"tiny5\">קצר 5</string>\r\n    <string name=\"tiny6\">קצר 6</string>\r\n    <string name=\"noSound\">שקט</string>\r\n\r\n    <!-- Vibration Mode -->\r\n    <string name=\"vibrate\">הפעל רטט</string>\r\n    <string name=\"vibrateDesc\">כאשר תתקבל אזעקת אמת, המכשיר ירטוט</string>\r\n\r\n    <!-- Secondary Vibration Mode -->\r\n    <string name=\"secondaryVibrate\">הפעל רטט</string>\r\n    <string name=\"secondaryVibrateDesc\">כאשר תתקבל התרעת משנה, המכשיר ירטוט</string>\r\n\r\n    <!-- Silent Mode Override -->\r\n    <string name=\"silentOverride\">עקוף מצב שקט</string>\r\n    <string name=\"silentOverrideDesc\">כאשר תתקבל אזעקת אמת, מצב שקט לא יחסום אותה</string>\r\n\r\n    <!-- Silent Mode Override -->\r\n    <string name=\"secondarySilentOverride\">עקוף מצב שקט</string>\r\n    <string name=\"secondarySilentOverrideDesc\">כאשר תתקבל התרעת משנה, מצב שקט לא יחסום אותה</string>\r\n\r\n    <!-- Early Warnings -->\r\n    <string name=\"earlyWarnings\">התרעות מקדימות</string>\r\n    <string name=\"earlyWarningsDesc\">הגדר התרעות מקדימות שיתקבלו 3-5 דקות לפני התרעות אמת</string>\r\n    <string name=\"receiveEarlyWarningsDesc\">קבל התרעות מקדימות 3-5 דקות לפני התרעות אמת</string>\r\n\r\n    <!-- Early Warning Sound -->\r\n    <string name=\"earlyWarningsSoundSelection\">צליל התרעות מקדימות</string>\r\n    <string name=\"earlyWarningsSoundSelectionDesc\">בחר צליל שיושמע כאשר תתקבל התרעה מקדימה</string>\r\n\r\n    <!-- Leave Shelter Alerts -->\r\n    <string name=\"leaveShelterAlerts\">התרעות סיום התגוננות</string>\r\n    <string name=\"leaveShelterDesc\">הגדר התרעות המנחות יציאה מהמרחב המוגן</string>\r\n    <string name=\"receiveLeaveShelterAlertsDesc\">קבל התרעות המנחות יציאה מהמרחב המוגן</string>\r\n\r\n    <!-- Leave Shelter Alert Sound -->\r\n    <string name=\"leaveShelterAlertsSoundSelection\">צליל התרעות סיום התגוננות</string>\r\n    <string name=\"leaveShelterAlertsSoundSelectionDesc\">בחר צליל שיושמע כאשר תתקבל התרעת סיום התגוננות</string>\r\n\r\n    <!-- I'm Safe -->\r\n    <string name=\"safe\">שלח \\\"אני במרחב מוגן\\\" </string>\r\n    <string name=\"safeCategory\">\\\"אני במרחב מוגן\\\"</string>\r\n    <string name=\"imSafeMessage\">אני במרחב מוגן - נשלח באמצעות צבע אדום באנדרואיד - https://redalert.me</string>\r\n    <string name=\"imSafeDesc\">שלח \\\"אני במרחב מוגן\\\"</string>\r\n\r\n    <!-- I'm Safe - WhatsApp Integration -->\r\n    <string name=\"safeWhatsApp\">שלח באמצעות WhatsApp</string>\r\n    <string name=\"safeWhatsAppDesc\">לחיצה על כפתור הדיווח תוביל ישירות לבחירת אנשי הקשר</string>\r\n\r\n    <!-- Language & Theme Selection -->\r\n    <string name=\"automatic\">אוטומטי</string>\r\n    <string name=\"languageAndTheme\">שפה ועיצוב</string>\r\n    <string name=\"langSelection\">בחירת שפה (Language)</string>\r\n    <string name=\"langSelectionDesc\">בחר שפה עבור ממשק האפליקציה</string>\r\n    <string name=\"themeSelection\">בחירת עיצוב</string>\r\n    <string name=\"themeSelectionDesc\">בחר עיצוב עבור ממשק האפליקציה</string>\r\n\r\n    <!-- Theme Name Identifiers -->\r\n    <string name=\"lightTheme\">בהיר</string>\r\n    <string name=\"darkTheme\">כהה</string>\r\n\r\n    <!-- Contact -->\r\n    <string name=\"contact\">צור קשר</string>\r\n    <string name=\"sentVia\">נשלח באמצעות</string>\r\n    <string name=\"problemDesc\">תיאור התקלה: </string>\r\n    <string name=\"debugInfo\">מיעד נוסף</string>\r\n    <string name=\"contactDesc\">צור איתנו קשר על-ידי שליחת אימייל</string>\r\n    <string name=\"reportProblem\">דווח על תקלה</string>\r\n    <string name=\"manualContact\">צור קשר בכתובת https://redalert.me</string>\r\n\r\n    <!-- Donate -->\r\n    <string name=\"donate\">תרומות יתקבלו בברכה</string>\r\n    <string name=\"donateInstructions\">בחר סכום לתרומה בשקלים:</string>\r\n    <string name=\"donateDesc\">כל תרומה תעזור בכיסוי עלויות הפיתוח והשרתים</string>\r\n    <string name=\"donateSuccess\">תודה רבה על תרומתך!</string>\r\n    <string name=\"donateSuccessDesc\">תרומתך מוערכת מאוד ותעזור בכיסוי עלויות הפיתוח והשרתים.</string>\r\n\r\n    <!-- Rate the App -->\r\n    <string name=\"rateApp\">דרג את האפליקציה</string>\r\n    <string name=\"rateAppDesc\">דרג אותנו בחנות של גוגל</string>\r\n\r\n    <!-- Volume -->\r\n    <string name=\"volume\">עוצמת צליל</string>\r\n    <string name=\"volumeDesc\">בחר עוצמת צליל לאזעקות אמת</string>\r\n\r\n    <!-- Secondary Volume -->\r\n    <string name=\"secondaryVolume\">עוצמת צליל</string>\r\n    <string name=\"secondaryVolumeDesc\">בחר עוצמת צליל להתרעות משנה</string>\r\n\r\n    <!-- Website -->\r\n    <string name=\"website\">בקר באתר שלנו</string>\r\n    <string name=\"websiteDesc\">בקר באתר הרשמי של האפליקציה</string>\r\n\r\n    <!-- Share the Application -->\r\n    <string name=\"share\">שיתוף</string>\r\n    <string name=\"shareDesc\">שתף את האפליקציה</string>\r\n    <string name=\"shareMessage\">אני משתמש באפליקציית \\\"צבע אדום\\\" באנדרואיד כדי לקבל התרעות על אזעקות צבע אדום  - https://redalert.me</string>\r\n\r\n    <!-- Self Test Result Dialogs -->\r\n    <string name=\"testingFCM\">שולח התרעת בדיקה... (1/2)</string>\r\n    <string name=\"testingPushy\">שולח התרעת בדיקה... (2/2)</string>\r\n    <string name=\"testFailed\">הבדיקה העצמית נכשלה לחלוטין. לא התקבלה התרעת בדיקה מאף שירות התרעות. בדוק את החיבור לאינטרנט ונסה מאוחר יותר, וצור איתנו קשר אם התקלה אינה חולפת.</string>\r\n    <string name=\"fcmTestFailed\">הבדיקה העצמית נכשלה חלקית. לא התקבלה התרעה דרך שרת ההתרעות של גוגל, אך כן התקבלה התרעה דרך שרת ההתרעות המשני. נסה שוב מאוחר יותר.</string>\r\n    <string name=\"pushyTestFailed\">הבדיקה העצמית נכשלה חלקית. לא התקבלה התרעה דרך שרת ההתרעות המשני, אך כן התקבלה התרעה דרך שרת ההתרעות של גוגל. נסה שוב מאוחר יותר.</string>\r\n\r\n    <!-- Error Messages -->\r\n    <string name=\"contactUsError\">אנא הזן הודעה באורך של יותר מ‑10 תווים.</string>\r\n    <string name=\"notifyError\">ארעה שגיאה בהצגת ההתרעה, מומלץ להפעיל מחדש את הטלפון.</string>\r\n    <string name=\"jsonFailed\">ארעה שגיאה בטעינת נתונים מהשרת.</string>\r\n    <string name=\"noGooglePlayServices\">הטלפון שלך אינו מכיל גרסה עדכנית של Google Play Services.</string>\r\n    <string name=\"pushRegistrationFailed\">ארעה שגיאת תקשורת בהרשמה לשירות העדכונים של האפליקציה.\\n\\nיש לבדוק שהחיבור לאינטרנט תקין.\\n\\nמידע טכני עקב התקלה:</string>\r\n    <string name=\"apiRequestFailed\">ארעה שגיאת תקשורת בטעינת נתונים מהשרת. בדוק את החיבור לאינטרנט ונסה שנית.</string>\r\n    <string name=\"registrationFailed\">ההרשמה לשירות העדכונים נכשלה. אנא נסה מאוחר יותר.</string>\r\n    <string name=\"grantNotificationPermission\">יש לאפשר קבלת התראות מהאפליקציה במסך הבא.</string>\r\n    <string name=\"citySelectionLimitError\">לא ניתן לבחור יותר מ-100 יישובים.</string>\r\n    <string name=\"multiSelectionSearchNoResults\">לא נמצאו תוצאות שתואמות את מילות החיפוש שהקלדת.</string>\r\n    <string name=\"multiSelectionSearchNoResultSelected\">לא בחרת יישוב או מרחב, יש לבחור לפחות תוצאה אחת ולנסות שוב.</string>\r\n\r\n    <!-- Success Messages -->\r\n    <string name=\"registrationID\">קוד הרשמה</string>\r\n    <string name=\"pushRegistrationSuccess\">בחר עיר מגורים</string>\r\n    <string name=\"pushRegistrationSuccessDesc\">עליך לבחור יישוב או עיר מגורים כדי לקבל התרעות בזמן אמת.</string>\r\n    <string name=\"pushRegistrationReselectDesc\">בגלל שינויים של פיקוד העורף, עליך לבחור מחדש יישוב או עיר מגורים כדי לקבל התרעות בזמן אמת.</string>\r\n\r\n    <!-- GPS -->\r\n    <string name=\"locationAlerts\">התרעות לפי מיקום</string>\r\n    <string name=\"locationAlertsDesc\">הגדר התרעות מבוססות מיקום כדי לקבל התרעות תוך כדי תנועה</string>\r\n    <string name=\"gpsEnabled\">התרעות לפי מיקום</string>\r\n    <string name=\"gpsEnabledDesc\">קבל התרעות לפי מיקומך בזמן אמת</string>\r\n    <string name=\"maxDistance\">מרחק מקסימלי</string>\r\n    <string name=\"maxDistanceDesc\">בחר את המרחק המקסימלי שלך מכל יישוב שמופעלת בו אזעקה</string>\r\n    <string name=\"kilometer\">ק\\\"מ</string>\r\n    <string name=\"nearbyCities\">יישובים בקרבתך</string>\r\n    <string name=\"noLocation\">ארעה שגיאה בקבלת מיקומך האחרון</string>\r\n    <string name=\"noNearbyCities\">אין יישובים בקרבתך, נסה להגדיל את המרחק המקסימלי</string>\r\n\r\n    <!-- GPS Frequency -->\r\n    <string name=\"gpsFrequency\">קצב דגימה</string>\r\n    <string name=\"gpsFrequencyDesc\">הגדר את הקצב שבו האפליקציה תאכן את מיקומך</string>\r\n    <string name=\"every\">כל</string>\r\n    <string name=\"minutes\">דקות</string>\r\n\r\n    <!-- GPS Notification -->\r\n    <string name=\"enableGPSDesc\">יש להפעיל את חיישן ה-GPS כדי לקבל התרעות לפי מיקום.</string>\r\n    <string name=\"enable\">הפעל</string>\r\n\r\n    <!-- Alert Share -->\r\n    <string name=\"shareAlert\">שתף את האזעקה</string>\r\n    <string name=\"alertSoundedAt\">ב</string>\r\n    <string name=\"alertSentVia\">נשלח באמצעות אפליקציית צבע אדום - התרעות בזמן אמת (https://redalert.me)</string>\r\n\r\n    <!-- Wake Screen -->\r\n    <string name=\"wakeScreen\">הדלק מסך</string>\r\n    <string name=\"wakeScreenDesc\">כאשר תתקבל אזעקת אמת, מסך הטלפון ידלק</string>\r\n\r\n    <!-- Alert Popup -->\r\n    <string name=\"close\">סגור</string>\r\n    <string name=\"silence\">השתק</string>\r\n    <string name=\"showPopup\">הצג פופאפ</string>\r\n    <string name=\"showPopupDesc\">כאשר תתקבל אזעקת אמת, יוצג פופאפ עם ספירה לאחור עד לזמן הנפילה המשוער</string>\r\n    <string name=\"grantOverlayPermission\">אפשר הצגה מעל אפליקציות אחרות</string>\r\n    <string name=\"grantOverlayPermissionInstructions\">בחר/י ״צבע אדום״ -> ״הצגה מעל אפליקציות אחרות״ במסך הבא.</string>\r\n    <string name=\"showSecondaryAlertPopupDesc\">כאשר תתקבל התרעת משנה, יוצג פופאפ עם ספירה לאחור עד לזמן הנפילה המשוער</string>\r\n\r\n    <!-- Schedule Exact Alarms -->\r\n    <string name=\"allowSettingExactAlarms\">אשר הגדרת שעונים מעוררים ותזכורות</string>\r\n    <string name=\"allowSettingExactAlarmsInstructions\">כדי לקבל התרעות צבע אדום בזמן אמת, אשר/י ״הגדרת שעונים מעוררים ותזכורות״ במסך הבא.</string>\r\n\r\n    <!-- Grant Notification Policy Access Permission -->\r\n    <string name=\"notificationPolicyAccessPermission\">קבלת התרעות במצב ״נא לא להפריע״</string>\r\n    <string name=\"notificationPolicyAccessPermissionInstructions\">כדי לקבל התרעות במצב ״נא לא להפריע״, בחר/י ״צבע אדום״ -> ״מתן גישה למצבים״ במסך הבא.</string>\r\n\r\n    <!-- Pushy Foreground Service -->\r\n    <string name=\"foregroundService\">שפר אמינות</string>\r\n    <string name=\"foregroundServiceDesc\">הצג התראה קבועה שתמנע ממערכת ההפעלה לכבות את האפליקציה ברקע</string>\r\n    <string name=\"pushy_foreground_service_title\">צבע אדום</string>\r\n    <string name=\"pushy_foreground_service_connected\">מחובר לשירות ההתרעות</string>\r\n    <string name=\"pushy_foreground_service_connecting\">מתחבר לשירות ההתרעות</string>\r\n    <string name=\"pushy_foreground_service_disconnected\">לא מחובר לשירות ההתרעות</string>\r\n\r\n    <!-- Threat Types -->\r\n    <string name=\"missiles\">ירי רקטות</string>\r\n    <string name=\"radiologicalEvent\">אירוע רדיולוגי</string>\r\n    <string name=\"earthQuake\">רעידת אדמה</string>\r\n    <string name=\"earlyWarning\">התרעה מקדימה</string>\r\n    <string name=\"leaveShelter\">סיום התגוננות</string>\r\n    <string name=\"tsunami\">סכנת צונאמי</string>\r\n    <string name=\"hostileAircraftIntrusion\">חדירת כלי טיס</string>\r\n    <string name=\"hazardousMaterials\">אירוע חומרים מסוכנים</string>\r\n    <string name=\"terroristInfiltration\">חדירת מחבלים</string>\r\n    <string name=\"missilesDrill\">תרגיל: ירי רקטות</string>\r\n    <string name=\"earthQuakeDrill\">תרגיל: רעידת אדמה</string>\r\n    <string name=\"radiologicalEventDrill\">תרגיל: אירוע רדיולוגי</string>\r\n    <string name=\"tsunamiDrill\">תרגיל: סכנת צונאמי</string>\r\n    <string name=\"hostileAircraftIntrusionDrill\">תרגיל: חדירת כלי טיס</string>\r\n    <string name=\"hazardousMaterialsDrill\">תרגיל: אירוע חומרים מסוכנים</string>\r\n    <string name=\"terroristInfiltrationDrill\">תרגיל: חדירת מחבלים</string>\r\n    <string name=\"unknown\">אזעקה</string>\r\n    <string name=\"system\">הודעת מערכת</string>\r\n\r\n    <!-- Threat Instructions -->\r\n    <string name=\"missilesInstructions\">היכנסו למרחב המוגן ושהו בו עד להודעה חדשה.</string>\r\n    <string name=\"hostileAircraftIntrusionInstructions\">היכנסו מיד למרחב המוגן ושהו בו עד להודעה חדשה.</string>\r\n    <string name=\"earthQuakeInstructions\">צאו מיד לשטח פתוח. אם לא ניתן, היכנסו לממ\"ד או לחדר מדרגות.</string>\r\n    <string name=\"earlyWarningInstructions\">בדקות הקרובות צפויה להתקבל התרעת אמת. עליך לשפר את מיקומך למיגון המיטבי בקרבתך. במקרה של קבלת התרעה, יש להיכנס למרחב המוגן ולשהות בו עד להודעה חדשה.</string>\r\n    <string name=\"leaveShelterInstructions\">ניתן לצאת מהמרחב המוגן.</string>\r\n    <string name=\"radiologicalEventInstructions\">היכנסו למבנה וסגרו את הדלתות והחלונות.</string>\r\n    <string name=\"terroristInfiltrationInstructions\">היכנסו מיד למבנה וסגרו את הדלתות והחלונות.</string>\r\n    <string name=\"tsunamiInstructions\">התרחקו מיד מחוף הים קילומטר אחד לפחות או עלו לקומה רביעית ומעלה.</string>\r\n    <string name=\"hazardousMaterialsInstructions\">היכנסו מיד למבנה וסגרו את הדלתות והחלונות.</string>\r\n\r\n    <!-- Localized News Flash Instructions -->\r\n    <string name=\"stayNearbyShelterInstructions\">שהייה בסמיכות למרחב מוגן</string>\r\n    <string name=\"continueStayingInsideShelterInstructions\">יש להמשיך לשהות במרחב המוגן</string>\r\n    <string name=\"checkPikudHaorefInstructions\">הישמעו להנחיות פיקוד העורף</string>\r\n    <string name=\"endStayNearbyShelterInstructions\">סיום שהייה בסמיכות למרחב מוגן</string>\r\n    <string name=\"missileThreatEndInstructions\">ירי רקטות וטילים - האירוע הסתיים</string>\r\n    <string name=\"earthQuakeThreatEndInstructions\">בעקבות רעידת האדמה - הנחיות לחזרה למבנים</string>\r\n    <string name=\"terroristInfiltrationThreatEndInstructions\">הסתיים אירוע חדירת מחבלים - ניתן לצאת מהבתים</string>\r\n    <string name=\"terroristInfiltrationConcernLiftedInstructions\">חדירת מחבלים - החשש הוסר</string>\r\n    <string name=\"hostileAircraftIntrusionThreatEndInstructions\">חדירת כלי טיס עוין - האירוע הסתיים</string>\r\n    <string name=\"leaveShelterButStayNearbyInstructions\">ניתן לצאת מהמרחב המוגן אך יש להישאר בקרבתו</string>\r\n\r\n    <!-- Country-Wide Alert -->\r\n    <string name=\"countryWideAlert\">ברחבי הארץ</string>\r\n\r\n    <!-- Custom Sound Selection Dialog -->\r\n    <string name=\"selectCustomSound\">בחר צליל מהטלפון</string>\r\n    <string name=\"selectCustomSoundDesc\">בחר/י צליל משלך על ידי לחיצה על ״צליל״ -> ״הצלילים שלי״ -> ״+״ -> ״שמירה״ במסך הבא.</string>\r\n\r\n    <!-- Battery Optimization Dialog -->\r\n    <string name=\"disableBatteryOptimizations\">ביטול אופטימיזציות סוללה</string>\r\n    <string name=\"disableBatteryOptimizationsInstructions\">כדי לקבל התרעות צבע אדום בזמן אמת, בחר/י ״סוללה״ -> ״לא מוגבל״ במסך הבא.</string>\r\n    <string name=\"disableBatteryOptimizationsInstructionsAndroid15\">כדי לקבל התרעות צבע אדום בזמן אמת, בחר/י ״שימוש בסוללה לאפליקציה״ -> ״הרשאה לשימוש ברקע״ -> סמנ/י ״ללא הגבלות״ במסך הבא.</string>\r\n    <string name=\"disableBatteryOptimizationsSamsungInstructions\">כדי לקבל התרעות צבע אדום בזמן אמת, בחר/י ״סוללה״ במסך הבא -> ״מטב את השימוש בסוללה״ -> ״יישומים ללא מיטוב״ -> ״הכל״ -> ״צבע אדום״ -> כבה/י את המיטוב עבור האפליקציה.</string>\r\n\r\n    <!-- Hide GPS Foreground Notification Dialog -->\r\n    <string name=\"hideGPSForegroundNotification\">איכון מיקום ברקע</string>\r\n    <string name=\"hideGPSForegroundNotificationInstructions\">לידיעתך, האפליקציה צריכה להציג התראה קבועה כדי שהיא תוכל לאכן את מיקומך ברקע.\\n\\nאפשר להסתירה על-ידי כיבוי ״הצגת התראות״ במסך הבא. האפליקציה תמשיך לאכן את מיקומך ברקע גם לאחר הסתרת ההתראה.</string>\r\n\r\n    <!-- Hide Pushy Foreground Notification Dialog -->\r\n    <string name=\"hidePushyForegroundNotification\">הסתרת ההתראה הקבועה</string>\r\n    <string name=\"hidePushyForegroundNotificationInstructions\">לידיעתך, האפליקציה צריכה להציג התראה קבועה כדי שהיא תוכל להמשיך לרוץ ברקע.\\n\\nאפשר להסתירה על-ידי כיבוי ״הצגת התראות״ במסך הבא. האפליקציה תמשיך לרוץ ברקע גם לאחר הסתרת ההתראה.</string>\r\n\r\n    <!-- Battery Optimization Reminder Setting -->\r\n    <string name=\"disableBatteryOptimizationsReminder\">חשוב: ביטול אופטימיזציות סוללה</string>\r\n    <string name=\"disableBatteryOptimizationsReminderDesc\">זיהינו כי עוד לא ביטלת אופטימיזציות סוללה עבור האפליקציה. כדי לקבל התרעות צבע אדום בזמן אמת, יש לבטל אופטימיזציות סוללה. לחץ כאן למידע נוסף.</string>\r\n\r\n    <!-- Clear Recent Alerts Dialog -->\r\n    <string name=\"clearRecentAlerts\">מחק התרעות אחרונות?</string>\r\n    <string name=\"clearRecentAlertsDesc\">האם תרצה למחוק את כל ההתרעות האחרונות?</string>\r\n\r\n    <!-- Operation Lifeshield -->\r\n    <string name=\"lifeshieldShelters\">מקלטי לייפשילד:</string>\r\n    <string name=\"learnAboutLifeshield\">למד עוד על לייפשילד</string>\r\n    <string name=\"learnAboutLifeshieldDesc\">למד עוד על לייפשילד, ארגון ללא מטרות רווח המציב מקלטים ברחבי ישראל.</string>\r\n\r\n    <!-- Time To Shelter -->\r\n    <string name=\"immediately\">מיידי</string>\r\n    <string name=\"fifteenSeconds\">15 שניות</string>\r\n    <string name=\"thirtySeconds\">30 שניות</string>\r\n    <string name=\"fortyFiveSeconds\">45 שניות</string>\r\n    <string name=\"oneMinute\">דקה</string>\r\n    <string name=\"oneMinuteAndAHalf\">דקה וחצי</string>\r\n    <string name=\"threeMinutes\">3 דקות</string>\r\n\r\n    <!-- Do not translate from here on down -->\r\n\r\n    <!-- Donation Amounts -->\r\n    <string name=\"donation_10\">₪10</string>\r\n    <string name=\"donation_20\">₪20</string>\r\n    <string name=\"donation_50\">₪50</string>\r\n    <string name=\"donation_100\">₪100</string>\r\n    <string name=\"donation_200\">₪200</string>\r\n\r\n    <!-- Static Language Identifiers -->\r\n    <string translatable=\"false\" name=\"english\">English</string>\r\n    <string translatable=\"false\" name=\"arabic\">عربي</string>\r\n    <string translatable=\"false\" name=\"spanish\">Español</string>\r\n    <string translatable=\"false\" name=\"russian\">Pусский</string>\r\n    <string translatable=\"false\" name=\"hebrew\">עברית</string>\r\n    <string translatable=\"false\" name=\"italian\">Italiano</string>\r\n    <string translatable=\"false\" name=\"french\">Français</string>\r\n    <string translatable=\"false\" name=\"german\">Deutsch</string>\r\n    <string translatable=\"false\" name=\"portuguese\">Português</string>\r\n\r\n    <!-- Preference Keys -->\r\n    <string translatable=\"false\" name=\"selfTestPref\">test</string>\r\n    <string translatable=\"false\" name=\"langPref\">lang</string>\r\n    <string translatable=\"false\" name=\"themePref\">theme</string>\r\n    <string translatable=\"false\" name=\"soundPref\">sound</string>\r\n    <string translatable=\"false\" name=\"websitePref\">website</string>\r\n    <string translatable=\"false\" name=\"fcmTokenPref\">gcm_registration_token</string>\r\n    <string translatable=\"false\" name=\"pushyTokenPref\">pushy_registration_token_v2</string>\r\n    <string translatable=\"false\" name=\"tutorialPref\">tutorial_1_0_24</string>\r\n    <string translatable=\"false\" name=\"donatePref\">donate</string>\r\n    <string translatable=\"false\" name=\"ratePref\">rating</string>\r\n    <string translatable=\"false\" name=\"lifeshieldPref\">lifeshie